# ==============================================================================
# Telegram Media Processing Pipeline - Environment Configuration (.env)
# Copy this file to `.env` in the root directory (`d:\Ideas\telebot\.env`)
# and fill in your actual credentials.
# ==============================================================================

# --- 1. Telegram Userbot Credentials (from https://my.telegram.org) ---
# Required for scraping raw files and uploading large video chunks via Hydrogram MTProto
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here
TG_USERBOT_SESSION=pipeline_userbot

# --- 2. Telegram Channel IDs ---
# Channel IDs in Telegram start with -100 (you can get them by forwarding a post to @getidsbot or @userinfobot)
RAW_CHANNEL_ID=-1001234567890       # Channel monitoring raw unstructured torrent drops
SHADOW_CHANNEL_ID=-1009876543210    # Shadow DB channel where renamed clean files + thumbnails are uploaded
MAIN_CHANNEL_ID=-1001112223334      # Presentation channel where final TMDB posters & batch links are posted

# --- 3. Human-in-the-Loop (HITL) Admin Bot & Authorization ---
ADMIN_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz        # Bot token from @BotFather for sending review cards
ADMIN_USER_ID=987654321                                     # Your personal numerical Telegram User ID (so only YOU can press Approve/Reject)

# --- 4. TMDB API Key (The Movie Database) ---
# 100% FREE! Create account -> Settings -> API -> copy API Key (v3 auth) from https://www.themoviedb.org/documentation/api
TMDB_API_KEY=your_tmdb_api_key_v3_here

# --- 5. External Batch Links Bot ---
LINKS_BOT_USERNAME=@YourLinksBot

# --- 6. Database & Redis URLs ---
DATABASE_URL=postgresql+asyncpg://pipeline:pipeline@localhost:5432/telegram_pipeline
REDIS_URL=redis://localhost:6379/0

# --- 7. Concurrency & Performance Settings ---
MAX_CONCURRENT_TRANSFERS=3
STATE_TTL_SECONDS=259200            # Redis intermediate state TTL (72 hours)
LOG_LEVEL=INFO
